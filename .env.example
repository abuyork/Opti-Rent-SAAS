# ---------------------------------------------------------------------------
# OptiRent environment configuration. Copy to `.env.local` and fill in.
# Every external key is server-side only (never prefixed NEXT_PUBLIC unless noted).
# ---------------------------------------------------------------------------

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# One-time report price in USD cents (default $49 = 4900). Config-driven per spec §7.
REPORT_PRICE_USD_CENTS=4900
# Secret used to sign report links (audit_id + email). Generate a long random string.
REPORT_LINK_SECRET=change-me-to-a-long-random-string

# --- Provider mode ---
# "mock" uses local fixtures (no external calls). "live" uses the real APIs below.
AIRROI_MODE=mock
CLAUDE_MODE=mock

# --- AirROI (STR data: listings, comparables, metrics) ---
AIRROI_API_KEY=
AIRROI_BASE_URL=https://api.airroi.com

# --- Claude (scoring engine) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Supabase (Postgres: audits, leads, payments, snapshots) ---
NEXT_PUBLIC_SUPABASE_URL=
# Service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Stripe (one-time USD payment) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email (Resend — "report ready" email with the report link) ---
# Without a key, emails are logged no-ops; audits are never blocked by email.
RESEND_API_KEY=
# Must be a verified sender/domain in Resend.
EMAIL_FROM=OptiRent <reports@rentlyn.com>

# --- Vision (cover-photo scoring) ---
OPTIRENT_VISION=true
OPTIRENT_VISION_MAX_IMAGES=6

# --- Testing ---
# Reveal the full report without payment (QA only — NEVER in production).
OPTIRENT_TESTING_UNLOCK_ALL=false
